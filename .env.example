# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real keys. If you suspect a key is leaked, rotate it immediately.

# --- Market data ---
# Required: FMP Premium is the v1 data provider.
FMP_API_KEY=
# Optional upgrades — auto-detected when populated (later phases).
POLYGON_API_KEY=
FRED_API_KEY=

# --- Execution (paper first; live is blocked behind the go-live gate) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# --- SEC EDGAR (contact email required in User-Agent) ---
SEC_USER_AGENT=you@example.com

# --- Optional: LLM analysis via OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
